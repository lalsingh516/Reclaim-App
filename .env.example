# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# FIREBASE_API_KEY: Optional. For real-time Firebase syncing, specify your Firebase API key.
FIREBASE_API_KEY=MY_FIREBASE_API_KEY

# FIREBASE_PROJECT_ID: Optional. Specify your Firebase Project ID.
FIREBASE_PROJECT_ID=MY_FIREBASE_PROJECT_ID

# FIREBASE_APP_ID: Optional. Specify your Firebase Android App ID.
FIREBASE_APP_ID=MY_FIREBASE_APP_ID
